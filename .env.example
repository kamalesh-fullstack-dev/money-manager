# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project settings (Project Settings -> Database -> Connection string)
# DATABASE_URL: "Transaction" pooler mode (port 6543) - used at runtime by the app
# DIRECT_URL: direct connection (port 5432) - used by Prisma for migrations
DATABASE_URL=
DIRECT_URL=
